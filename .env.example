# ═══════════════════════════════════════════════════════════════════════════
# Vertex CRM — Environment Variable Reference
# Copy this file to .env.local for local dev; use Secret Manager in GCP prod.
# NEVER commit a filled-in copy of this file to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── GCP Project ──────────────────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT_EMAIL=vertex-crm-sa@your-gcp-project-id.iam.gserviceaccount.com

# ── Database (Cloud SQL PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgresql://vertex_app:STRONG_PASSWORD@/vertex_crm?host=/cloudsql/PROJECT:REGION:INSTANCE
CLOUD_SQL_INSTANCE=your-gcp-project-id:us-central1:vertex-crm-db

# ── Redis (Memorystore) ───────────────────────────────────────────────────────
REDIS_URL=redis://10.0.1.0:6379

# ── Google Identity Platform / Firebase ──────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
JWT_AUDIENCE=your-firebase-project-id
# Frontend only:
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Paddle Billing (Merchant of Record — works from Costa Rica) ─────────────
# Get these from https://vendors.paddle.com → Developer Tools → Authentication
PADDLE_ENV=production            # or 'sandbox' for testing
PADDLE_API_KEY=pdl_live_apikey_...
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...
# Price IDs from Paddle Dashboard → Catalog → Products → Prices
PADDLE_PRICE_STARTER=pri_...
PADDLE_PRICE_GROWTH=pri_...
PADDLE_PRICE_SCALE=pri_...
PADDLE_PRICE_ENTERPRISE=pri_...
# Frontend (Paddle.js overlay checkout)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_...
NEXT_PUBLIC_PADDLE_ENV=production

# ── Vertex AI ─────────────────────────────────────────────────────────────────
VERTEX_VECTOR_SEARCH_INDEX=projects/PROJECT/locations/REGION/indexes/INDEX_ID
VERTEX_VECTOR_SEARCH_ENDPOINT=projects/PROJECT/locations/REGION/indexEndpoints/ENDPOINT_ID
VERTEX_GEMINI_MODEL=gemini-1.5-pro-001
VERTEX_GEMINI_FLASH_MODEL=gemini-1.5-flash-001

# ── BigQuery ──────────────────────────────────────────────────────────────────
BIGQUERY_DATASET=vertex_analytics
BIGQUERY_LOCATION=US

# ── GCS Buckets ───────────────────────────────────────────────────────────────
GCS_KB_BUCKET=vertex-crm-kb-documents
GCS_UPLOADS_BUCKET=vertex-crm-uploads

# ── META (Facebook/Instagram) API ────────────────────────────────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_API_VERSION=v19.0
# Per-tenant tokens stored encrypted in connector_configs table (not here)

# ── TikTok Business API ───────────────────────────────────────────────────────
TIKTOK_APP_ID=your-tiktok-app-id
TIKTOK_APP_SECRET=your-tiktok-app-secret

# ── Google Ads API ────────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=your-random-verify-token
# Per-tenant phone number IDs and tokens stored in channel_configs table

# ── Cal.com Booking ───────────────────────────────────────────────────────────
CALCOM_API_BASE=https://api.cal.com/v2
# Per-tenant Cal.com API keys stored in tenant_agent_configs table

# ── SendGrid (Email Notifications) ───────────────────────────────────────────
SENDGRID_API_KEY=SG.xxx...
SENDGRID_FROM_EMAIL=noreply@vertex-crm.io
SENDGRID_FROM_NAME=Vertex CRM

# ── Twilio (SMS Notifications) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxx...
TWILIO_AUTH_TOKEN=xxx...
TWILIO_FROM_NUMBER=+1555000000

# ── Internal Service URLs (Cloud Run — set automatically by Terraform outputs) ─
CRM_SERVICE_URL=https://crm-service-xxxx-uc.a.run.app
MARKETING_SERVICE_URL=https://marketing-intelligence-xxxx-uc.a.run.app
AGENT_SERVICE_URL=https://ai-sales-agent-xxxx-uc.a.run.app
WORKFLOW_SERVICE_URL=https://workflow-engine-xxxx-uc.a.run.app
NOTIFICATION_SERVICE_URL=https://notification-service-xxxx-uc.a.run.app
BILLING_SERVICE_URL=https://billing-service-xxxx-uc.a.run.app
EMBEDDING_SERVICE_URL=https://embedding-service-xxxx-uc.a.run.app

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.vertex-crm.io
APP_URL=https://app.vertex-crm.io

# ── Pub/Sub Topics ────────────────────────────────────────────────────────────
PUBSUB_LEAD_EVENTS_TOPIC=vertex-lead-events
PUBSUB_AI_AGENT_TOPIC=vertex-ai-agent-agent-events
PUBSUB_BILLING_TOPIC=vertex-billing-events
PUBSUB_MARKETING_SYNC_TOPIC=vertex-marketing-sync
PUBSUB_WORKFLOW_TOPIC=vertex-workflow-events
PUBSUB_NOTIFICATION_TOPIC=vertex-notification-events
